---
import Section from "../components/ui/Section.astro";
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../components/layout/BaseLayout.astro";
import ContentList from "../components/shared/ContentList.astro";
import Container from "../components/ui/Container.astro";

const siteCollection = await getCollection("site");
if (!siteCollection || siteCollection.length === 0) {
  throw new Error("Site configuration not found");
}

const site = siteCollection[0].data;

const formatDate = (date: Date | undefined) => {
  if (!date) return "";
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
};

const formatExperienceDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const posts = await getCollection(
  "blog",
  ({ data }: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? !data.draft : true;
  }
);
const latestPosts = posts
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  )
  .slice(0, 3);

const experiences = await getCollection("experience");
const sortedExperiences = experiences.sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) =>
    b.data.startDate.getTime() - a.data.startDate.getTime()
);

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((project: CollectionEntry<"projects">) => {
    if (import.meta.env.PROD && project.data.draft) return false;
    return project.data.featured;
  })
  .slice(0, 3);
---

<BaseLayout title={`${site.name} — ${site.title}`} description={site.introduction}>
  <Container>
    <section class="hero">
      <p class="eyebrow">Full-stack · Real-time systems · Web3</p>
      <h1>{site.name}</h1>
      <p class="subtitle">{site.title}</p>
      <p class="introduction">{site.introduction}</p>
      {
        site.socialLinks && (
          <div class="social-links">
            {site.socialLinks.map(({ platform, url }) => {
              const isTel = url.startsWith("tel:");
              const isMail = url.startsWith("mailto:");
              const external = !isTel && !isMail;
              return (
                <a
                  href={url}
                  target={external ? "_blank" : undefined}
                  rel={external ? "noopener noreferrer" : undefined}
                >
                  {platform}
                </a>
              );
            })}
          </div>
        )
      }
    </section>

    <!-- Blogs to be added later -->
    <!-- 
    <Section>
      <div class="section-header">
        <h2>{site.sections.blog.title}</h2>
        <a href="/blog">{site.sections.blog.viewAllText}</a>
      </div>
      <ContentList>
        {
          latestPosts.map((post) => (
            <article>
              <div class="title-row">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
                {post.data.publishedAt && (
                  <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
                )}
              </div>
              <p class="muted-text">{post.data.description}</p>
            </article>
          ))
        }
      </ContentList>
    </Section> -->

    <Section class="section">
      <div class="section-header">
        <h2>{site.sections.experience.title}</h2>
        <a href="/experience">{site.sections.experience.viewAllText}</a>
      </div>
      <ContentList>
        {
          sortedExperiences.slice(0, 2).map((exp) => (
            <article>
              <div class="title-row">
                <div class="company-info">
                  <img src={exp.data.logo} alt="" class="company-logo" />
                  <a
                    href={exp.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {exp.data.title}
                  </a>
                </div>
                <span class="exp-dates">
                  <time datetime={exp.data.startDate.toISOString()}>
                    {formatExperienceDate(exp.data.startDate)}
                  </time>
                  {" — "}
                  {exp.data.current ? (
                    <span class="exp-present">Present</span>
                  ) : exp.data.endDate ? (
                    <time datetime={exp.data.endDate.toISOString()}>
                      {formatExperienceDate(exp.data.endDate)}
                    </time>
                  ) : null}
                </span>
              </div>
              <p class="muted-text">{exp.data.description}</p>
              {exp.data.highlights && exp.data.highlights.length > 0 && (
                <ul class="exp-highlights">
                  {exp.data.highlights.slice(0, 2).map((line) => (
                    <li>{line}</li>
                  ))}
                </ul>
              )}
            </article>
          ))
        }
      </ContentList>
    </Section>

    <section class="section">
      <div class="section-header">
        <h2>{site.sections.projects.title}</h2>
        <a href="/projects">{site.sections.projects.viewAllText}</a>
      </div>
      <ContentList>
        {
          featuredProjects.map((project) => (
            <article>
              <div class="title-row">
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.data.title}
                </a>
              </div>
              <p class="muted-text">{project.data.description}</p>
              {project.data.techs && (
                <div class="tags">
                  {project.data.techs.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </ContentList>
    </section>

    {site.skills && (
      <section class="section">
        <div class="section-header">
          <h2>{site.sections.skills.title}</h2>
        </div>
        <div class="skills-grid">
          {Object.entries(site.skills).map(([category, skills]) => (
            <div class="skill-category">
              <h3 class="skill-category-title">{category}</h3>
              <div class="skill-tags">
                {skills.map((skill) => (
                  <span class="skill-tag">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {site.education && (
      <section class="section">
        <div class="section-header">
          <h2>{site.sections.education.title}</h2>
        </div>
        <div class="education-info">
          <div class="education-item">
            <h3 class="education-degree">{site.education.degree}</h3>
            <p class="education-institution">{site.education.institution}</p>
            <div class="education-details">
              <span class="education-duration">{site.education.duration}</span>
              <span class="education-cgpa">CGPA: {site.education.cgpa}</span>
            </div>
          </div>
        </div>
      </section>
    )}
  </Container>
</BaseLayout>

<style>
  main {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .hero {
    padding: 2.5rem 0;
  }

  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin: 0 0 0.75rem;
  }

  .introduction {
    margin: 1.5rem 0;
    opacity: 0.9;
    line-height: 1.65;
  }

  .exp-highlights {
    margin: 0.75rem 0 0;
    padding-left: 1.1rem;
    font-size: var(--text-xs);
    line-height: 1.5;
    opacity: 0.72;
  }

  .exp-highlights li {
    margin-bottom: 0.35rem;
  }

  .section {
    margin: 4rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .section-header a {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--accent-primary);
    text-decoration: none;
  }

  .section-header a:hover {
    color: var(--link-hover-color);
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    font-size: var(--text-sm);
    flex-wrap: wrap;
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .company-logo {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }

  .company-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .exp-dates {
    font-size: var(--text-xs);
    color: var(--text-dates);
    white-space: nowrap;
    flex-shrink: 0;
    text-align: right;
  }

  .exp-dates time {
    color: inherit;
  }

  .exp-present {
    color: var(--accent-primary);
    font-weight: 500;
  }

  time {
    font-size: var(--text-xs);
    opacity: 0.5;
    white-space: nowrap;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .tags span {
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    opacity: 0.7;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 1rem;
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-category-title {
    font-size: var(--text-sm);
    font-weight: 600;
    opacity: 0.8;
    margin: 0;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: var(--text-xs);
    padding: 0.35rem 0.65rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    color: var(--text-muted);
  }

  .education-info {
    margin-top: 1rem;
  }

  .education-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .education-degree {
    font-size: var(--text-base);
    font-weight: 600;
    margin: 0;
    opacity: 0.9;
  }

  .education-institution {
    font-size: var(--text-sm);
    opacity: 0.7;
    margin: 0;
  }

  .education-details {
    display: flex;
    gap: 1rem;
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    main {
      padding: 1rem 0;
    }

    .hero {
      padding: 3rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .title-row {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }

    .exp-dates {
      text-align: left;
      white-space: normal;
    }

    .skills-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
