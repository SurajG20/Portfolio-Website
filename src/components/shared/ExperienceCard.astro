---
interface Props {
  title: string;
  description: string;
  url: string;
  logo?: string;
  highlights?: string[];
  startDate: Date;
  endDate?: Date;
  current?: boolean;
  isExternal?: boolean;
}

const {
  title,
  description,
  url,
  logo,
  highlights,
  startDate,
  endDate,
  current = false,
  isExternal = false,
} = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
---

<article class="content-card">
  <div class="card-content">
    {logo && (
      <div class="card-logo">
        <img src={logo} alt={`${title} logo`} width="48" height="48" />
      </div>
    )}
    <div class="card-header">
      <h3 class="card-title">
        <a
          href={url}
          target={isExternal ? "_blank" : "_self"}
          rel={isExternal ? "noopener noreferrer" : ""}
        >
          {title}
        </a>
      </h3>
      <div class="date-range">
        <time datetime={startDate.toISOString()}>{formatDate(startDate)}</time>
        {" — "}
        {
          current ? (
            <span class="present">Present</span>
          ) : endDate ? (
            <time datetime={endDate.toISOString()}>{formatDate(endDate)}</time>
          ) : null
        }
      </div>
    </div>
    <p class="card-description">{description}</p>
    {
      highlights && highlights.length > 0 && (
        <ul class="highlights">
          {highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .content-card {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    background: var(--surface-elevated);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .content-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
  }

  .card-logo {
    margin-bottom: 1rem;
  }

  .card-logo img {
    border-radius: 8px;
    object-fit: cover;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .card-title {
    font-size: var(--text-xl);
    margin: 0;
  }

  .card-title a {
    color: var(--text-color);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--primary-color);
  }

  .card-description {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
  }

  .highlights {
    margin: 1rem 0 0;
    padding-left: 1.15rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  .highlights li {
    margin-bottom: 0.5rem;
  }

  .highlights li:last-child {
    margin-bottom: 0;
  }

  .date-range {
    font-size: var(--text-xs);
    color: var(--text-dates);
    white-space: nowrap;
    text-align: right;
  }

  .date-range time {
    color: inherit;
  }

  .present {
    color: var(--accent-primary);
    font-weight: 500;
  }
</style>
